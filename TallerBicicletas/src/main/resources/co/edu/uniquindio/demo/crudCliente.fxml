<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="500.0" style="-fx-background-color: #E7F8BE;"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.demo.viewController.ClienteViewController">
    <children>

        <Text layoutX="31.0" layoutY="56.0" strokeType="OUTSIDE" strokeWidth="0.0"
              text="Gestión Clientes" wrappingWidth="223.0">
            <font>
                <Font name="Arial Black" size="23.0" />
            </font>
        </Text>

        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="370.0" layoutY="20.0"
                   pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@recursospng/456212.png" />
            </image>
        </ImageView>

        <VBox layoutX="23.0" layoutY="80.0" prefWidth="454.0" spacing="10">


            <HBox spacing="10">
                <TextField fx:id="txtId" promptText="ID" prefWidth="100.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
                <TextField fx:id="txtNombre" promptText="Nombre Completo" prefWidth="200.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="txtTelefono" promptText="Teléfono" prefWidth="150.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
                <TextField fx:id="txtDireccion" promptText="Dirección" prefWidth="290.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
            </HBox>


            <HBox spacing="10">
                <Button fx:id="btnAgregar" onAction="#onAgregar"
                        style="-fx-background-color: #41B97D;" text="Agregar">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
                <Button fx:id="btnEliminar" onAction="#onEliminar"
                        style="-fx-background-color: #FCC5F8;" text="Eliminar">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
                <Button fx:id="btnBuscar" onAction="#onBuscar"
                        style="-fx-background-color: #B3F7FE;" text="Buscar">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
            </HBox>

            <Label fx:id="lblMensaje"/>


            <TableView fx:id="tblClientes" prefHeight="250.0" prefWidth="454.0">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80.0"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150.0"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="110.0"/>
                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="110.0"/>
                </columns>
            </TableView>


            <Button fx:id="btnVolver" onAction="#onVolver"
                    style="-fx-background-color: #41B97D;" text="Volver">
                <font><Font name="Arial Bold" size="12.0"/></font>
            </Button>

        </VBox>
    </children>
</AnchorPane>