<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="534.0" prefWidth="585.0" style="-fx-background-color: #E7F8BE;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.demo.viewController.BicicletaViewController">
    <children>

        <Text layoutX="14.0" layoutY="39.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Gestión Bicicletas" wrappingWidth="223.0">
            <font>
                <Font name="Arial Black" size="23.0" />
            </font>
        </Text>

        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="370.0" layoutY="20.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@recursospng/456212.png" />
            </image>
        </ImageView>

        <VBox layoutX="23.0" layoutY="80.0" prefHeight="403.0" prefWidth="539.0" spacing="10">

            <HBox spacing="10">
                <TextField fx:id="txtSerial" prefWidth="150.0" promptText="Número Serial" style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77" /></color></DropShadow></effect>
                </TextField>
                <TextField fx:id="txtMarca" prefWidth="150.0" promptText="Marca" style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77" /></color></DropShadow></effect>
                </TextField>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="txtColor" prefWidth="150.0" promptText="Color" style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77" /></color></DropShadow></effect>
                </TextField>
                <TextField fx:id="txtAno" prefWidth="100.0" promptText="Año" style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77" /></color></DropShadow></effect>
                </TextField>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="txtIdPropietario" prefWidth="150.0" promptText="ID Propietario" style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77" /></color></DropShadow></effect>
                </TextField>
                <ComboBox fx:id="cmbTipo" prefWidth="150.0" promptText="Tipo" />
            </HBox>

            <HBox spacing="10">
                <Button fx:id="btnAgregar" onAction="#onAgregar" style="-fx-background-color: #41B97D;" text="Agregar">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Button>
                <Button fx:id="btnEliminar" onAction="#onEliminar" style="-fx-background-color: #FCC5F8;" text="Eliminar">
                    <font><Font name="Arial Bold" size="12.0" /></font>
                </Button>
            </HBox>

            <Label fx:id="lblMensaje" />


            <TableView fx:id="tblBicicletas" prefHeight="200.0" prefWidth="481.0">
                <columns>
                    <TableColumn fx:id="colSerial" prefWidth="103.20001029968262" text="Serial" />
                    <TableColumn fx:id="colMarca" prefWidth="74.4000244140625" text="Marca" />
                    <TableColumn fx:id="colTipo" prefWidth="88.80000305175781" text="Tipo" />
                    <TableColumn fx:id="colColor" prefWidth="77.5999755859375" text="Color" />
                    <TableColumn fx:id="colAno" prefWidth="60.79998779296875" text="Año" />
                    <TableColumn fx:id="colPropietario" prefWidth="128.79998779296875" text="Propietario" />
                </columns>
            </TableView>

            <Button fx:id="btnVolver" onAction="#onVolver" style="-fx-background-color: #41B97D;" text="Volver">
                <font><Font name="Arial Bold" size="12.0" /></font>
            </Button>

        </VBox>
    </children>
</AnchorPane>
