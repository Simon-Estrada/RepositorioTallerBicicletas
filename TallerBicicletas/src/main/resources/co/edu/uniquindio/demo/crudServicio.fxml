<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="750.0" prefWidth="550.0" style="-fx-background-color: #E7F8BE;"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.demo.viewController.ServicioViewController">
    <children>

        <Text layoutX="31.0" layoutY="50.0" text="Gestión Servicios">
            <font><Font name="Arial Black" size="23.0"/></font>
        </Text>

        <VBox layoutX="23.0" layoutY="70.0" prefWidth="504.0" spacing="10">

            <!-- Datos del servicio -->
            <HBox spacing="10">
                <TextField fx:id="txtId" promptText="ID Servicio" prefWidth="150.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
                <DatePicker fx:id="dpFechaIngreso" promptText="Fecha Ingreso" prefWidth="200.0"/>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="txtIdBicicleta" promptText="Serial Bicicleta" prefWidth="150.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
                <TextField fx:id="txtIdMecanico" promptText="ID Mecánico" prefWidth="150.0"
                           style="-fx-background-color: #F0FBD6;">
                    <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
                </TextField>
            </HBox>

            <TextField fx:id="txtMotivo" promptText="Motivo" prefWidth="400.0"
                       style="-fx-background-color: #F0FBD6;">
                <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
            </TextField>

            <TextField fx:id="txtDiagnostico" promptText="Diagnóstico" prefWidth="400.0"
                       style="-fx-background-color: #F0FBD6;">
                <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
            </TextField>

            <TextField fx:id="txtTrabajoRealizado" promptText="Trabajo Realizado" prefWidth="400.0"
                       style="-fx-background-color: #F0FBD6;">
                <effect><DropShadow><color><Color red="0.77" green="0.77" blue="0.77"/></color></DropShadow></effect>
            </TextField>

            <!-- Seccion repuestos -->
            <HBox spacing="10">
                <ComboBox fx:id="cmbRepuestos" promptText="Seleccionar Repuesto" prefWidth="250.0"/>
                <Button fx:id="btnAgregarRepuesto" onAction="#onAgregarRepuesto"
                        style="-fx-background-color: #B3F7FE;" text="Agregar Repuesto">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
            </HBox>

            <Label fx:id="lblCosto" text="Costo Total: $0.0"/>

            <!-- Botones principales -->
            <HBox spacing="10">
                <Button fx:id="btnCrear" onAction="#onCrear"
                        style="-fx-background-color: #41B97D;" text="Crear Servicio">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
                <Button fx:id="btnBuscar" onAction="#onBuscar"
                        style="-fx-background-color: #B3F7FE;" text="Buscar">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
                <Button fx:id="btnConsultarFecha" onAction="#onConsultarFecha"
                        style="-fx-background-color: #FCC5F8;" text="Consultar por Fecha">
                    <font><Font name="Arial Bold" size="12.0"/></font>
                </Button>
            </HBox>

            <Label fx:id="lblMensaje"/>
            <Label fx:id="lblAlertaStock" style="-fx-text-fill: red;"/>

            <!-- Tabla servicios -->
            <TableView fx:id="tblServicios" prefHeight="200.0" prefWidth="504.0">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80.0"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100.0"/>
                    <TableColumn fx:id="colBicicleta" text="Bicicleta" prefWidth="100.0"/>
                    <TableColumn fx:id="colMecanico" text="Mecánico" prefWidth="100.0"/>
                    <TableColumn fx:id="colCosto" text="Costo" prefWidth="80.0"/>
                </columns>
            </TableView>

            <Button fx:id="btnVolver" onAction="#onVolver"
                    style="-fx-background-color: #41B97D;" text="Volver">
                <font><Font name="Arial Bold" size="12.0"/></font>
            </Button>

        </VBox>
    </children>
</AnchorPane>